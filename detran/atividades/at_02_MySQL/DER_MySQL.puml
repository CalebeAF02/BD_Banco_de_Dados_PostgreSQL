@startuml DER_DETRAN_MySQL

title Diagrama Entidade-Relacionamento - DETRAN\nMySQL

skinparam linetype ortho
skinparam padding 10
skinparam margin 20
skinparam nodesep 100
skinparam ranksep 150
skinparam minClassWidth 150

skinparam class {
    BorderColor #333333
    ArrowColor #333333
}

entity "PROPRIETÁRIO" as proprietario {
    * cpf : VARCHAR(11) <<KEY>>
    --
    nome : VARCHAR(100)
    endereco : VARCHAR(150)
    bairro : VARCHAR(50)
    cidade : VARCHAR(50)
    estado : VARCHAR(2)
    sexo : CHAR(1)
    data_nascimento : DATE
    idade : INT
}

entity "VEÍCULO" as veiculo {
    * placa : VARCHAR(8) <<KEY>>
    --
    chassi : VARCHAR(17)
    cor_predominante : VARCHAR(20)
    ano_fabricacao : INT
    cpf_proprietario : VARCHAR(11) <<FK>>
    cod_modelo : INT <<FK>>
    cod_categoria : INT <<FK>>
}

entity "MODELO" as modelo {
    * cod_modelo : INT <<KEY>>
    --
    descricao : VARCHAR(100)
    marca : VARCHAR(50)
}

entity "CATEGORIA" as categoria {
    * cod_categoria : INT <<KEY>>
    --
    descricao : VARCHAR(50)
}

entity "TIPO_INFRAÇÃO" as tipo_infraçao {
    * cod_infacao : INT <<KEY>>
    --
    descricao : VARCHAR(150)
    valor : DECIMAL(10,2)
}

entity "OCORRÊNCIA_INFRAÇÃO" as ocorrencia {
    * id_ocorrencia : INT <<KEY>>
    --
    placa_veiculo : VARCHAR(8) <<FK>>
    cod_tipo_infacao : INT <<FK>>
    cod_local : INT <<FK>>
    matricula_agente : INT <<FK>>
    data_hora : DATETIME
    velocidade_aferida : INT
}

entity "LOCAL" as local {
    * cod_local : INT <<KEY>>
    --
    localizacao : VARCHAR(150)
    velocidade_permitida : INT
    latitude : DECIMAL(10,8)
    longitude : DECIMAL(10,8)
}

entity "AGENTE_TRANSITO" as agente {
    * matricula : INT <<KEY>>
    --
    nome : VARCHAR(100)
    data_contratacao : DATE
    tempo_servico : INT
}

entity "TELEFONE_PROPRIETÁRIO" as telefone {
    * cpf_proprietario : VARCHAR(11) <<FK, KEY>>
    * numero : VARCHAR(15) <<KEY>>
    --
    tipo : VARCHAR(20)
}

proprietario ||--o{ veiculo : possui
veiculo }o--|| modelo : tem
veiculo }o--|| categoria : pertence
veiculo ||--o{ ocorrencia : "envolvido em"
tipo_infraçao ||--o{ ocorrencia : registrada
local ||--o{ ocorrencia : "ocorre em"
agente ||--o{ ocorrencia : "registra"
proprietario ||--o{ telefone : "tem"

note right of proprietario
    Entidade central de proprietários
    Identificada pelo CPF
    Sistema: MySQL
end note

note right of ocorrencia
    Representa cada infração registrada
    Relaciona veículo, tipo de infração,
    local, data/hora e agente responsável
end note

@enduml
